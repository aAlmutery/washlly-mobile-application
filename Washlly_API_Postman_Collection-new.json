  "item": [
    {
      "name": "01 - Customer Login and Session",
      "item": [
        {
          "name": "customer-login-by-phone - direct login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "apikey",
                "value": "{{anonKey}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{anonKey}}"
              }
            ],
            "description": "Creates or resumes a direct customer web session without OTP. If the phone has no saved name and customer_name is omitted, the response returns requires_name=true.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_phone\": \"{{customerPhone}}\",\n  \"customer_name\": \"{{customerName}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{functionsBase}}/customer-login-by-phone"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test(\"Direct customer login response is successful\", function () {",
                  "  pm.expect(data.success).to.eql(true);",
                  "});",
                  "if (data.session_token) pm.collectionVariables.set(\"customerSessionToken\", data.session_token);",
                  "if (data.customer_phone) pm.collectionVariables.set(\"customerPhoneNormalized\", data.customer_phone);",
                  "if (data.customer_name) pm.collectionVariables.set(\"customerName\", data.customer_name);",
                  "pm.test(\"OTP is not required for the current customer flow\", function () {",
                  "  pm.expect(data.requires_verification).to.not.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "customer-update-profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "apikey",
