            "url": {
              "raw": "{{restBase}}/bookings?select=*,services(name,price),stations(name)&order=created_at.desc&limit=2&id=eq.02f1d9dd-4ebe-4614-9236-3be6485aba2a",
              "host": [
                "{{restBase}}"
              ],
              "path": [
                "bookings"
              ],
              "query": [
                {
                  "key": "customer_phone",
                  "value": "eq.{{customerPhone}}",
                  "disabled": true
                },
                {
                  "key": "select",
